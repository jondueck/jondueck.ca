---
layout: base.njk
---

<style>
    body {
        --theme: var(--secondary-color);
        --theme-contrast: #e93e3e;
    }
    .sticker {
        filter: drop-shadow(0.5px 0.5px 0.5px var(--black) );
        transition-duration: 0.25s;
        will-change: filter;
        {# transform: rotate(-2deg); #}
        width: fit-content;
        margin-inline: auto;
    }
    .cal {
        display: grid !important;
        grid-template-columns: repeat(2, 1fr);
        @media (min-width: 45rem) {
            grid-template-columns: repeat(4, 1fr);
        }
        width: 100% !important;
        padding-inline: 1em;
        gap: 1em;
        {# gap: 0 !important; #}

    }
    .cal-item {
        padding: 1lh;
        border: 1px solid;
        {# aspect-ratio: 1/1; #}
        min-height: 50vh;
        & > * + * {
            margin-block-start: 1em;
        }

        grid-template-areas: "top " "mid" "bot";
        display: grid;
        grid-template-rows: auto 1fr auto;\
        &:nth-of-type(even) {
            background: var(--secondary-color);
        }

    }
    .cal-date {
        grid-area: top;
    }
    .grid-content {
        grid-area: mid;
    }
    .cal-stats {
        grid-area: bot;
        display: flex;
        text-align: center;
        justify-content: space-around;
        justify-content: space-evenly;
        display: none;
    }

    .cal-stat,
    .stat {
        flex: 1 1 auto;
    }

    .cal-content ul {
        margin: 0;
        padding: 0;
        li {
            border-bottom: 1px solid;
            min-height: 1lh;

        }
    }

    .sched {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        grid-gap: 0;
        width: 100%;
        max-width: 100%;
        text-align: center;
        max-width: 50rem;
    }

    .sched-item {
        aspect-ratio: 1/1;
        padding: 1lh;
        display: flex;
        justify-content: center;
        align-items: center;
        border: 2px solid var(--theme);
    }
    .sched-item:nth-of-type(2),
    .sched-item:nth-of-type(3) {
        background: var(--secondary-color);
        color: var(--background);
    }
    {# .sticker:hover {
        filter: drop-shadow(1px 1px 1px var(--black) );
    } #}
</style>

