<style>
    :root {
        --gold: #F4CD63;
        --gold: color-mix(in srgb, #F4CD63 66%, #fbb03b);
        --white: #f4f5ed;
    }
    body {
        --serif: schoolbook-condensed, ivypresto-text, serif;
        font-family: var(--serif);
        text-transform: uppercase;
        * {
            font-family: inherit;
        }
    }
    ::selection {
        background: var(--gold);
        color: var(--background);
    }
    #main {
        padding-block: 15vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }
    .site-header,
    .site-footer {
        display: none;
    }
    .credit {
        font-family: var(--sans);
        font-size: 0.625em;
        text-transform: uppercase;
    }
    .menu {
        list-style: none;
        {# list-style: '◦'; #}
        padding: 0;
        margin: 0;
    }
    .menu li {
        margin-bottom: 1lh;
    }
    .credit {
        display: block;
        opacity: 0.8;
    }
    header {
        margin-bottom: 1lh;
    }
    a.credit,
    .credit a {
        text-decoration: none;
    }
    a.credit:hover,
    .credit a:hover {
        text-decoration: wavy underline;
        color: var(--red);
    }

    .garland{
        rotate: deg;
        letter-spacing: -0.5ch;

        :nth-child(4n+1) {
            color: var(--red);;
        }
        :nth-child(4n+2) {
            color: #ccc;
        }
        :nth-child(4n+3) {
            color: var(--primary-color);
            {# color: #84D6A1; #}
        }
        :nth-child(4n+4) {
            color: var(--purple);
        }
    }
    h1 {
        color: var(--gold);
        {# text-transform: uppercase; #}
        font-size: 3.5em;
        font-weight: 400;
        margin-block-end: 1em;
        {# letter-spacing: 0.05em; #}
        {# text-shadow:
        -1px -1px 0 var(--body-color),  /* Top-left shadow */
        1px -1px 0 var(--body-color),  /* Top-right shadow */
        -1px  1px 0 var(--body-color),  /* Bottom-left shadow */
        1px  1px 0 var(--body-color);  /* Bottom-right shadow */ #}
    }
</style>

